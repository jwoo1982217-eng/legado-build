<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape>
            <solid android:color="#FFF9EE" />
            <corners
                android:topLeftRadius="30dp"
                android:topRightRadius="30dp" />
        </shape>
    </item>

    <item
        android:width="190dp"
        android:height="108dp"
        android:gravity="top|end"
        android:right="0dp"
        android:top="4dp"
        android:drawable="@drawable/decor_listen_willow" />

    <item
        android:width="260dp"
        android:height="96dp"
        android:bottom="0dp"
        android:gravity="bottom|start"
        android:left="-18dp"
        android:drawable="@drawable/decor_listen_mountain" />

</layer-list>
