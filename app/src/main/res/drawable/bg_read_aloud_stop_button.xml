<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:left="2dp"
        android:top="4dp">
        <shape android:shape="oval">
            <solid android:color="#3A4F6F32" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="3dp">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#FFA6C78A"
                android:centerColor="#FF7F9A56"
                android:endColor="#FF5F7D3F" />
        </shape>
    </item>

</layer-list>
