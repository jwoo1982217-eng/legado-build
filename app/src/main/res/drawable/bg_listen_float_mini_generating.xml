<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:left="3dp"
        android:top="5dp"
        android:right="1dp">
        <shape android:shape="oval">
            <solid android:color="#2FA6C78A" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="3dp">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#FFFFF7E8"
                android:centerColor="#FFE8F1E1"
                android:endColor="#FFA6C78A" />
        </shape>
    </item>

    <item
        android:left="8dp"
        android:top="6dp"
        android:right="20dp"
        android:bottom="24dp">
        <shape android:shape="oval">
            <solid android:color="#70FFFFFF" />
        </shape>
    </item>

</layer-list>
